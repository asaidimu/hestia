    "_audit_log_": {
      "path": "internal/app/audit/schema/access_log.schema.json",
      "hash": "sha256:46f8d00dacbed16175bb78f83b59a560898ea0950c7f3800cd6f40b086087707",
      "version": "1.0.0",
      "schema": {
        "version": "1.0.0",
        "name": "_audit_log_",
        "description": "Audit trail of security-relevant actions: who did what, to what, when, from where, and with what outcome.",
        "fields": {
          "019f65b3-d3e4-7021-aa73-19c16c747eb6": {
            "name": "recorded_at",
            "description": "ISO-8601 timestamp of when this record was written. Compare with occurred_at to detect ingestion lag or clock skew.",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-70b1-b9a7-66665c4d3983": {
            "name": "trace_id",
            "description": "Distributed trace/correlation ID linking this event to related events across services.",
            "type": "string"
          },
          "019f65b3-d3e4-70d4-9dcb-b08d10798318": {
            "name": "region",
            "description": "Deployment region or data center of the emitting service.",
            "type": "string"
          },
          "019f65b3-d3e4-70f2-954e-c078a0d74b4e": {
            "name": "session_id",
            "description": "Non-secret session/token identifier. Never store raw credentials, tokens, or secrets here.",
            "type": "string"
          },
          "019f65b3-d3e4-7171-aa1c-2e37e433345b": {
            "name": "resource_id",
            "description": "Identifier of the specific resource instance acted upon.",
            "type": "string"
          },
          "019f65b3-d3e4-73bd-9199-06ce692d9093": {
            "name": "occurred_at",
            "description": "ISO-8601 timestamp of when the audited action actually took place.",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-74d1-9c20-a6d199cf1b70": {
            "name": "metadata",
            "description": "Additional producer-specific context that doesn't warrant a first-class field.",
            "type": "record"
          },
          "019f65b3-d3e4-7545-b93f-dfce85a54bbe": {
            "name": "event_name",
            "description": "Fine-grained, human-readable event taxonomy, e.g. \"user.login.failed\" or \"invoice.updated\". Complements operation/resource_type with producer-specific detail.",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-757d-8cd3-5207c6d7d958": {
            "name": "latency_ms",
            "description": "Duration of the underlying operation, in milliseconds.",
            "type": "integer"
          },
          "019f65b3-d3e4-7637-931b-27558af15fdd": {
            "name": "auth_method",
            "type": "enum",
            "schema": {
              "id": "019f65b3-d3e4-7ed1-82f7-4fd86ab0e4ea"
            }
          },
          "019f65b3-d3e4-7681-9846-340535e27ccb": {
            "name": "user_agent",
            "type": "string"
          },
          "019f65b3-d3e4-77f7-b01f-4853f19f2651": {
            "name": "service_name",
            "description": "The service/component that emitted this audit record.",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-78da-bddf-2ed076a26a21": {
            "name": "status",
            "required": true,
            "type": "enum",
            "schema": {
              "id": "019f65b3-d3e4-7bb9-bf4e-6f62ae863543"
            }
          },
          "019f65b3-d3e4-78e5-9ca9-fa9caf58b685": {
            "name": "actor_type",
            "required": true,
            "type": "enum",
            "schema": {
              "id": "019f65b3-d3e4-7acc-9b9d-9789d2049126"
            }
          },
          "019f65b3-d3e4-790a-96c2-69f2d5931eea": {
            "name": "source_ip",
            "description": "Originating IP address of the actor.",
            "type": "string"
          },
          "019f65b3-d3e4-7a91-adde-07a5cf26c8c2": {
            "name": "on_behalf_of_id",
            "description": "Set when actor_id is acting on behalf of another identity (delegation/impersonation), e.g. an admin or service acting for a user.",
            "type": "string"
          },
          "019f65b3-d3e4-7b19-82b7-51fefc6ee322": {
            "name": "actor_id",
            "description": "Identifier of who or what performed the action. Use \"system\" for automated/internal actors.",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-7bd3-b702-5dcb79b1e58a": {
            "name": "integrity_hash",
            "description": "Hash of this record chained with the previous record's hash, for tamper-evidence. Populated by the log writer, never by the emitting service.",
            "type": "string"
          },
          "019f65b3-d3e4-7c4f-9751-3bc4dd183df5": {
            "name": "error_code",
            "description": "Machine-readable error/denial code, present when status is failure, denied, or error.",
            "type": "string"
          },
          "019f65b3-d3e4-7c7c-b357-eecfdf5cef15": {
            "name": "event_id",
            "description": "Unique identifier for this audit record itself (UUIDv7).",
            "required": true,
            "unique": true,
            "type": "string"
          },
          "019f65b3-d3e4-7c89-9c6a-2df577c21fbf": {
            "name": "resource_type",
            "description": "The kind of resource acted upon, e.g. \"invoice\", \"user_account\", \"api_key\".",
            "required": true,
            "type": "string"
          },
          "019f65b3-d3e4-7d9d-a2f3-da8ac99d8d14": {
            "name": "error_message",
            "description": "Human-readable error detail. Avoid embedding secrets or PII beyond what's already logged elsewhere.",
            "type": "string"
          },
          "019f65b3-d3e4-7dc8-bcf4-6f3e2cfa624b": {
            "name": "operation",
            "description": "Coarse-grained action category, for consistent filtering across all producers.",
            "required": true,
